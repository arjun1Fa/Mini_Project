# Copy to .env and fill in your values
# Never commit .env to source control

# ── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...   # service_role key (NOT anon key)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret   # from Dashboard → Settings → API

# ── Firebase (for FCM push notifications) ──────────────────────
FIREBASE_CREDENTIALS_JSON=/path/to/firebase-service-account.json

# ── ML Model directory ──────────────────────────────────────────
MODEL_DIR=./models

# ── Image quality thresholds ────────────────────────────────────
BLUR_THRESHOLD=100
BRIGHTNESS_THRESHOLD=50
MAX_IMAGE_SIZE_MB=10

# ── Flask ───────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
PORT=8080
